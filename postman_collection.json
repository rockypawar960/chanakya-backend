            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"responses\": {\n    \"1\": 10,\n    \"2\": 9,\n    \"3\": \"In teams\",\n    \"4\": \"Mathematics\",\n    \"5\": 10,\n    \"6\": 8,\n    \"7\": 9,\n    \"8\": \"Hybrid\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:8080/api/assessments/submit",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "assessments", "submit"]
            }
          }
        },
